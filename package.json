{
  "name": "copilot-agent-team",
  "version": "0.1.0",
  "description": "Multi-agent system using GitHub Copilot CLI ACP with orchestration, memory, and real-time dashboard",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npx tsx src/index.ts",
    "dev:watch": "npx tsx --watch src/index.ts",
    "demo": "npx tsx src/index.ts --demo",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
